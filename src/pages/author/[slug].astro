---
import Layout from "@/layouts/Layout.astro";
import { getCollection, getEntry } from "astro:content";
import BlogItem from "@/components/BlogItem.astro";
import AppFooter from "@/components/AppFooter.astro";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.map((author) => ({
    params: { slug: author.data.slug },
    props: { author },
  }));
}

const { author } = Astro.props as { author: any };

if (!author) {
  return Astro.redirect("/404");
}

const posts = await getCollection("posts", ({ data }) => {
  return data.author === author.data.slug;
});

posts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const ogImageUrl = author.data.image || undefined;
---

<Layout title={`${author.data.name} - Author`} image={ogImageUrl}>
  <div class="px-5 lg:px-0 pb-10 pt-10">
    <!-- Author profile -->
    <div class="mb-12">
      <div class="flex flex-col md:flex-row gap-8 items-start">
        <!-- Author image -->
        {
          author.data.image && (
            <div class="flex-shrink-0">
              <img
                src={author.data.image}
                alt={author.data.name}
                class="rounded-md w-48 h-48 md:rounded-full object-cover"
              />
            </div>
          )
        }

        <!-- Author info -->
        <div class="flex-grow">
          <h1 class="text-4xl lg:text-5xl mb-4 leading-tight">
            {author.data.name}
          </h1>

          <!-- Author bio -->
          {
            author.data.bio && (
              <div class="prose prose-lg max-w-none mb-6">
                <Fragment set:html={author.data.bio} />
              </div>
            )
          }

          <!-- Author links -->
          {
            author.data.links && author.data.links.length > 0 && (
              <div class="flex flex-wrap gap-3">
                {author.data.links.map((link: any) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm cursor-underline-effect"
                  >
                    {link.title}
                  </a>
                ))}
              </div>
            )
          }

          <!-- Post count -->
          <div class="mt-6">
            <p class="text-sm" style="color: var(--color-text-muted)">
              {posts.length}
              {posts.length === 1 ? "post" : "posts"} published
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Author's posts -->
    {
      posts.length > 0 && (
        <div>
          <h2 class="text-2xl mb-6 md:hidden">Articles</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 2xl:grid-cols-3 3xl:grid-cols-4 gap-6">
            {posts.map((post) => (
              <BlogItem
                title={post.data.title}
                description={post.data.description}
                mainImage={post.data.mainImage}
                publishedAt={post.data.publishedAt.toISOString()}
                external_link={post.data.external_link}
                slug={post.id.replace(/\.md$/, "")}
                is_art_only={
                  post.data.categories.length === 1 &&
                  post.data.categories[0] === "art"
                }
              />
            ))}
          </div>
        </div>
      )
    }

    {
      posts.length === 0 && (
        <div class="text-center py-12">
          <p style="color: var(--color-text-muted)">
            {author.data.name} hasn't published any posts yet.
          </p>
        </div>
      )
    }

    <!-- Navigation footer -->
    <div class="mt-12 pt-8 pb-4">
      <a href="/blog" class="text-sm cursor-after-effect">&larr; Back to blog</a
      >
    </div>
  </div>
</Layout>
