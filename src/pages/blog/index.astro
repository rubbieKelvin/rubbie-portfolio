---
import Layout from "@/layouts/Layout.astro";
import BlogItem from "@/components/BlogItem.astro";
import AppFooter from "@/components/AppFooter.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? true : true;
});

posts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

function excerpt(body: string, len = 100) {
  const plain = body
    .replace(/^#+\s+.*$/gm, "")
    .replace(/^```[\s\S]*?```$/gm, "")
    .replace(/!\[.*?\]\(.*?\)/g, "")
    .replace(/\[([^\]]*)\]\(.*?\)/g, "$1")
    .replace(/[*_~`>#-]/g, "")
    .replace(/\s+/g, " ")
    .trim();
  return plain.length > len ? plain.slice(0, len).trimEnd() + "..." : plain;
}
---

<Layout title="Blog">
  <div class="px-5 lg:px-0">
    <div class="pt-10 py-15">
      <div class="flex items-center justify-between">
        <h1 class="text-5xl">
          <span class="animate-pulse">&gt;</span><span>Blog</span>
        </h1>
        <a href="/rss.xml" class="mt-1 text-sm cursor-underline-effect text-gray-500">~ $ wget rss.xml</a>
      </div>
      <h2 class="mt-3 xl:max-w-[70%] text-text-muted">
        Thoughts, tutorials, and insights from my development journey, sharing
        things i learn & create along the way.
      </h2>
    </div>

    <!-- listing -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 2xl:grid-cols-3 3xl:grid-cols-4 gap-6 mt-2 pb-10"
    >
      {
        posts.map((post) => {
          return (
            <BlogItem
              title={post.data.title}
              description={post.data.description ?? ''}
              short_content={excerpt(post.body || "")}
              mainImage={post.data.mainImage}
              publishedAt={post.data.publishedAt.toISOString()}
              external_link={post.data.external_link}
              slug={post.id.replace(/\.md$/, "")}
              is_art_only={
                post.data.categories.length === 1 &&
                post.data.categories[0] === "art"
              }
            />
          );
        })
      }
    </div>
    <AppFooter />
  </div>
</Layout>
